---
import Layout from '../layouts/Layout.astro';
import { AppProvider } from '../providers/AppProvider';

// Generate metadata dynamically (similar to Next.js generateMetadata)
const metadata = {
  title: 'BGX - AI Background Remover',
  description: 'Free online AI background removal tool. Remove image backgrounds instantly in your browser with complete privacy protection. No upload needed, all processing done locally.',
  keywords: [
    'background removal',
    'AI background remover',
    'image editing',
    'remove background',
    'photo editor',
    'privacy',
    'local processing',
    'free tool',
    'BGX'
  ],
  ogImage: '/og-image.png',
  ogImageAlt: 'BGX - AI Background Removal Tool',
  siteName: 'BGX',
  locale: 'en_US',
};
---

<Layout 
  title={metadata.title}
  description={metadata.description}
  keywords={metadata.keywords.join(', ')}
  ogImage={metadata.ogImage}
  ogImageAlt={metadata.ogImageAlt}
  siteName={metadata.siteName}
  locale={metadata.locale}
>
  <AppProvider client:load />
</Layout>
